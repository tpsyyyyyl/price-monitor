# Groq API key — get a free one at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Secret for signing JWT tokens — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Optional: Telegram bot for price-drop alerts
# TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# TELEGRAM_CHAT_ID=123456789

# Optional: custom local SQLite path (defaults to ./price_monitor.db)
# DATABASE_PATH=./price_monitor.db

# Optional: full database URL (defaults to local SQLite ./price_monitor.db)
# DATABASE_URL=postgresql+psycopg://user:pass@host/dbname
